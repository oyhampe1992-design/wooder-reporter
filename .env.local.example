# ──────────────────────────────────────────────
# WOODER REPORTER — Variables d'environnement
# Renommer ce fichier en .env.local
# NE JAMAIS committer .env.local sur GitHub !
# ──────────────────────────────────────────────

# OpenAI — Whisper transcription
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — Claude rapport IA
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — Stockage audio + base sessions
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ──────────────────────────────────────────────
# Dans Vercel : Settings → Environment Variables
# Ajouter chacune de ces variables
# ──────────────────────────────────────────────
